{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(pnpm add:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm --version:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm test:coverage:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm why:*)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm list:*)",
      "Bash(node --version:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs pnpm exec prettier --write"
          }
        ]
      }
    ]
  }
}
